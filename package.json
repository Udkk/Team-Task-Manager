{
  "name": "express-mongoose-api",
  "version": "1.0.0",
  "description": "Node.js and Express backend API with MongoDB connection.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "build": "npm --prefix client install --include=dev && npm --prefix client run build",
    "dev": "nodemon src/server.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "start": "node src/server.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
